S3_SECRET_KEY="rustfsadmin"
S3_BUCKET="spotteur"

SMTP_HOST="inbucket"
SMTP_PORT="25"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@example.com"

NOVU_SECRET_KEY=""
NEXT_PUBLIC_NOVU_APP_IDENTIFIER=""
