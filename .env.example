NEXT_PUBLIC_NOVU_WS_URL="wss://ws.novu.co"

TEMPORAL_ADDRESS="temporal:7233"

SELENIUM_REMOTE_URL="http://selenium:4444/wd/hub"

TRUSTED_ORIGINS="${APP_URL}"

BROWSER_ENGINE_TYPE="selenium"

BROWSERLESS_WS_ENDPOINT=""
BROWSERLESS_TOKEN=""

PLAYWRIGHT_CHROME_URL=""
