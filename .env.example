APP_ENV="production"
APP_URL="http://localhost:18000"

DB_HOST="postgres-webapp"
DB_PORT="5432"
DB_USER="spotteur"
DB_PASSWORD="spotteur"
DB_NAME="spotteurdb"

BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="${APP_URL}"

RUSTFS_INITIAL_ACCESS_KEY="rustfsadmin"
RUSTFS_INITIAL_SECRET_KEY="rustfsadmin"

FILESYSTEM_DISK="rustfs"
USE_EXTERNAL_SELENIUM="false"

S3_ENDPOINT="http://host.docker.internal:18002"
